{
  "name": "etag-mini",
  "version": "0.1.0",
  "description": "Compute strong/weak ETags for strings, buffers, streams. Includes If-Match / If-None-Match comparison helpers. Zero dependencies (Node crypto only).",
  "keywords": ["etag", "http", "if-match", "if-none-match", "cache"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=20" },
  "author": { "name": "Vlad Bordei", "email": "bordeivlad@gmail.com", "url": "https://github.com/p-vbordei" },
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/p-vbordei/etag.git" },
  "bugs": { "url": "https://github.com/p-vbordei/etag/issues" },
  "homepage": "https://github.com/p-vbordei/etag#readme",
  "devDependencies": { "@types/node": "^20.0.0", "typescript": "^5.5.0", "vitest": "^2.0.0" }
}
